          },
          {
            "name": "days_late",
            "expr": "source.days_late",
            "displayName": "Days Late"
          },
          {
            "name": "is_late",
            "expr": "source.is_late",
            "displayName": "Is Late"
          },
          {
            "name": "payment_method",
            "expr": "source.payment_method",
            "displayName": "Payment Method"
          },
          {
            "name": "invoice_status",
            "expr": "source.invoice_status",
            "displayName": "Invoice Status"
          },
          {
            "name": "transaction_ref",
            "expr": "source.transaction_ref",
            "displayName": "Transaction Ref"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "name": "total_payments",
            "expr": "COUNT(*)",
            "comment": "Total number of payments",
            "displayName": "Total Payments"
          },
          {
            "name": "late_payments_count",
            "expr": "COUNT_IF(source.is_late = TRUE)",
            "comment": "Number of late payments",
            "displayName": "Late Payments Count"
          },
          {
            "name": "late_payment_rate",
            "expr": "MEASURE(late_payments_count) * 100.0 / MEASURE(total_payments)",
            "comment": "Percentage of payments that were late",
            "displayName": "Late Payment Rate (%)"
          },
          {
            "name": "avg_days_late",
            "expr": "AVG(source.days_late)",
            "comment": "Average number of days late across all payments",
            "displayName": "Avg Days Late"
          },
          {
            "name": "total_amount_paid",
            "expr": "SUM(source.amount_paid)",
            "comment": "Sum of all payment amounts",
            "displayName": "Total Amount Paid"
          }
        ]
      }
    },
    {
      "name": "4e9e5ecb",
      "displayName": "average_score_by_semester",
      "queryLines": [
        "SELECT \r\n",
        "    semester_id,\r\n",
        "    ROUND(AVG(score), 2) AS average_score\r\n",
        "FROM \r\n",
        "    school.gold.fact_student_performance\r\n",
        "GROUP BY \r\n",
        "    semester_id\r\n",
        "ORDER BY \r\n",
        "    semester_id ASC;"
      ],
      "catalog": "school",
      "schema": "gold"
    },
    {
      "name": "ef29ebe5",
      "displayName": "collected_by_month",
      "queryLines": [
        "SELECT\r\n",
        "    MONTH(CAST(payment_date AS DATE)) AS month,\r\n",
        "    ROUND(SUM(amount_paid), 2) AS collected\r\n",
        "FROM\r\n",
        "    school.gold.fact_payments\r\n",
        "GROUP BY\r\n",
        "    1, YEAR(CAST(payment_date AS date))\r\n",
        "ORDER BY\r\n",
        "    1;"
      ]
    }
  ],
